[Unit]
Description=Twitter Thread Scheduler Bot
After=network.target

[Service]
Type=simple
User=<your-pi-username>
WorkingDirectory=/home/<your-pi-username>/twitter-scheduler
EnvironmentFile=/home/<your-pi-username>/twitter-scheduler/.env
ExecStart=/home/<your-pi-username>/twitter-scheduler/venv/bin/python bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
